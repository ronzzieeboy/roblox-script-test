import json
from discord_webhook import DiscordWebhook

url = input("Paste your Discord Webhook URL and press Enter: ").strip()

msg = input("Type your message and press Enter: ")

try:
    count_input = input("How many times do you want to send this? ")
    count = int(count_input)
except ValueError:
    print("Invalid number. Defaulting to 1 time.")
    count = 1

for i in range(count):
    webhook = DiscordWebhook(url=url, content=msg)
    
    try:
        response = webhook.execute()
        
        if response is False or (hasattr(response, 'status_code') and response.status_code == 404):
            print("Error: Webhook No Where to be Found")
            break
        else:
            print(f"Sent successfully! ({i + 1}/{count})")
            
    except (json.decoder.JSONDecodeError, Exception):
        print("Error: Webhook No Where to be Found")
        break
